# Homebridge connection
HOMEBRIDGE_URL=http://homebridge:8581
HOMEBRIDGE_USERNAME=admin
HOMEBRIDGE_PASSWORD=changeme
# HOMEBRIDGE_OTP=
HOMEBRIDGE_NOAUTH=false

# Exporter settings
EXPORTER_LISTEN_ADDR=:9090
EXPORTER_CONFIG_PATH=/config/accessories.yaml
EXPORTER_POLL_INTERVAL=30s
EXPORTER_REQUEST_TIMEOUT=10s
